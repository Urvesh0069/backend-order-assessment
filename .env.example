# =============================================================================
# Single env template for the whole project. Each app loads its OWN .env from
# its own folder, so copy the relevant section:
#   - VITE_* vars           -> frontend/.env   (read by Vite)
#   - everything under BACKEND -> backend/.env  (read by dotenv, cwd = backend/)
# =============================================================================

# ------------------------------- FRONTEND ------------------------------------
VITE_API_BASE_URL=http://localhost:4000

# ------------------------------- BACKEND -------------------------------------
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
JWT_SECRET=replace_with_a_long_random_string

# --- Storage ---
# STORAGE_DRIVER=local -> saves to ./local_gcs (no GCP setup needed)
# STORAGE_DRIVER=gcs   -> uploads to a real bucket (set the vars below)
STORAGE_DRIVER=local
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET_NAME=your-bucket-name

# service-account creds (leave blank to use gcloud ADC instead)
GCS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Database shards: SHARD_COUNT, then one connection block per shard ---
SHARD_COUNT=4

SHARD0_HOST=localhost
SHARD0_PORT=5432
SHARD0_USER=postgres
SHARD0_PASSWORD=postgres
SHARD0_DATABASE=orders_shard0

SHARD1_HOST=localhost
SHARD1_PORT=5433
SHARD1_USER=postgres
SHARD1_PASSWORD=postgres
SHARD1_DATABASE=orders_shard1

SHARD2_HOST=localhost
SHARD2_PORT=5434
SHARD2_USER=postgres
SHARD2_PASSWORD=postgres
SHARD2_DATABASE=orders_shard2

SHARD3_HOST=localhost
SHARD3_PORT=5435
SHARD3_USER=postgres
SHARD3_PASSWORD=postgres
SHARD3_DATABASE=orders_shard3
