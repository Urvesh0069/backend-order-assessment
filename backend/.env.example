# Storage: "local" saves uploads to ./local_gcs (no GCP setup needed).
# Switch to "gcs" to upload to a real bucket.
#
# Auth option A — explicit service-account credentials in env (no key file on disk):
#   Set GCS_CLIENT_EMAIL + GCS_PRIVATE_KEY below. Keep the quotes; the "\n"
#   escapes are converted to real newlines at runtime. Never commit real values.
# Auth option B — Application Default Credentials (leave the two vars blank):
#   Local machine: gcloud auth application-default login
#   GCP (GKE/Run): attached service account / Workload Identity (nothing to set)
STORAGE_DRIVER=local
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET_NAME=your-bucket-name
GCS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# One block per shard.
SHARD_COUNT=4

SHARD0_HOST=localhost
SHARD0_PORT=5432
SHARD0_USER=postgres
SHARD0_PASSWORD=postgres
SHARD0_DATABASE=orders_shard0

SHARD1_HOST=localhost
SHARD1_PORT=5433
SHARD1_USER=postgres
SHARD1_PASSWORD=postgres
SHARD1_DATABASE=orders_shard1

SHARD2_HOST=localhost
SHARD2_PORT=5434
SHARD2_USER=postgres
SHARD2_PASSWORD=postgres
SHARD2_DATABASE=orders_shard2

SHARD3_HOST=localhost
SHARD3_PORT=5435
SHARD3_USER=postgres
SHARD3_PASSWORD=postgres
SHARD3_DATABASE=orders_shard3

JWT_SECRET=replace_with_a_long_random_string
PORT=4000
LOG_LEVEL=info
NODE_ENV=development
